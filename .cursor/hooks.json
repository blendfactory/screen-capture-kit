{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/dart-fix.sh",
        "timeout": 45
      }
    ],
    "afterTabFileEdit": [
      {
        "command": ".cursor/hooks/dart-fix.sh",
        "timeout": 45
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/verify.sh",
        "timeout": 180,
        "loop_limit": 5
      }
    ]
  }
}
